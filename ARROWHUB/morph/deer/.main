-- แปลงร่างกวาง --
local lp = game.Players.LocalPlayer
local targetID = "97766074054212" 

pcall(function()
    local oldChar = lp.Character
    local oldCFrame = oldChar:GetPrimaryPartCFrame()
    local Objects = game:GetObjects("rbxassetid://" .. targetID)
    local NewChar = Objects[1]
    
    if NewChar then
        NewChar.Name = lp.Name
        NewChar.Parent = workspace
        
        -- เสกให้สูงไว้ก่อน
        NewChar:SetPrimaryPartCFrame(oldCFrame * CFrame.new(0, 5, 0))
        
        lp.Character = NewChar
        local hum = NewChar:FindFirstChildOfClass("Humanoid")
        local hrp = NewChar:FindFirstChild("HumanoidRootPart") or NewChar:FindFirstChild("Torso")
        workspace.CurrentCamera.CameraSubject = hum

        -- [[ ⚡ ระบบวาร์ปเดิน (ตัดปัญหาเดินไม่ได้/ขาจม) ]] --
        local speed = 0.5 -- ความเร็วในการวาร์ป (ปรับเพิ่มได้ถ้าอยากเดินเร็ว)
        local floatHeight = 11.7 -- << ถ้าเท้ายังจม ให้แก้เลขนี้เป็น 6.0 หรือ 7.0

        game:GetService("RunService").Heartbeat:Connect(function()
            if hrp and hum.MoveDirection.Magnitude > 0 then
                -- สั่งวาร์ปตัวละครไปข้างหน้าตามปุ่มที่กด
                local targetPos = hrp.Position + (hum.MoveDirection * speed)
                hrp.CFrame = CFrame.new(targetPos, targetPos + hum.MoveDirection)
            end
            
            -- [[ ⚡ บังคับความสูงตายตัว (กันมุดดินถาวร) ]] --
            if hrp then
                local ray = Ray.new(hrp.Position + Vector3.new(0, 2, 0), Vector3.new(0, -50, 0))
                local hit, pos = workspace:FindPartOnRay(ray, NewChar)
                if hit then
                    -- บังคับให้เท้าลอยเหนือจุดที่ Ray ยิงไปโดนพื้น
                    hrp.CFrame = CFrame.new(hrp.Position.X, pos.Y + floatHeight, hrp.Position.Z) * (hrp.CFrame - hrp.Position)
                end
            end
        end)

        -- ล้างฟิสิกส์ให้หมด กันมันดีด
        for _, v in pairs(NewChar:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
                v.Massless = true
                v.Anchored = false -- ต้องไม่ Anchored ถึงจะวาร์ปได้ลื่น
            end
        end
        if hrp then hrp.CanCollide = true end

        oldChar:Destroy()
        print("ARROW HUB: ระบบวาร์ปเดินเปิดใช้งานแล้ว! จมดินไม่ได้แน่นอน!")
    end
end)
