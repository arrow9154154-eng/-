-- แปลงร่างตัวดำ --
local lp = game.Players.LocalPlayer
local targetID = "95601377852860" 

pcall(function()
    local oldChar = lp.Character
    local oldAnimate = oldChar:FindFirstChild("Animate")
    
    local Objects = game:GetObjects("rbxassetid://" .. targetID)
    local NewChar = Objects[1]
    local oldCFrame = oldChar:GetPrimaryPartCFrame()
    
    NewChar.Name = lp.Name
    NewChar.Parent = workspace
    NewChar:SetPrimaryPartCFrame(oldCFrame)
    lp.Character = NewChar
    
    local hum = NewChar:FindFirstChildOfClass("Humanoid")
    local hrp = NewChar:FindFirstChild("HumanoidRootPart")
    workspace.CurrentCamera.CameraSubject = hum

    -- [[ ⚡ FIX: กันดีดถอยหลัง & ปรับฟิสิกส์ ]] --
    for _, v in pairs(NewChar:GetDescendants()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            v.CanCollide = false -- ปิดการชนชิ้นส่วนอื่น ไม่ให้มันฟาดพื้นจนดีด
            v.Massless = true    -- ทำให้น้ำหนักเบา จะได้ไม่ถ่วงฟิสิกส์
        end
    end

    if hrp then
        hrp.RootPriority = 127 -- ตั้งค่าลำดับความสำคัญสูงสุด
        -- ดักจับตอนขยับเพื่อล้างแรงดีด
        game:GetService("RunService").Stepped:Connect(function()
            if hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall then
                local vel = hrp.Velocity
                if vel.Y > 0 then -- ขณะกำลังลอยขึ้น
                    -- บังคับให้ความเร็วแนวนอน (X, Z) ไม่ดีดกลับด้าน
                    hrp.Velocity = Vector3.new(vel.X, vel.Y, vel.Z)
                end
            end
        end)
    end

    -- [[ 🏃‍♂️ ใส่ระบบท่าทาง ]] --
    if oldAnimate then
        local newAnimate = oldAnimate:Clone()
        if NewChar:FindFirstChild("Animate") then NewChar.Animate:Destroy() end
        newAnimate.Parent = NewChar
        newAnimate.Disabled = false
    end

    oldChar:Destroy()
    print("ARROW HUB: แก้ระบบกระโดดสปริงถอยหลังแล้ว! ลองทดสอบดูแอโร่!")
end)
