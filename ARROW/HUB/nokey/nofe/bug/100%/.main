 -- ไม้บัคสีทอง -- 
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local backpack = player:WaitForChild("Backpack")

-- 1. สร้าง Tool 
local tool = Instance.new("Tool")
tool.Name = "ไม้บัคสีทอง"
tool.RequiresHandle = true
tool.Parent = backpack

-- 2. สร้างด้ามไม้ (Black & Gold)
local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(20, 20, 20)
handle.Material = Enum.Material.Wood
handle.Parent = tool

local function createGoldRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.35, 0.1, 0.35)
    ring.Color = Color3.fromRGB(255, 215, 0)
    ring.Material = Enum.Material.Metal
    ring.CanCollide = false
    ring.Parent = tool
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = handle
    weld.Part1 = ring
    weld.Parent = ring
    ring.CFrame = handle.CFrame * CFrame.new(0, offset, 0)
end

createGoldRing(-1.2)
createGoldRing(-0.8)

-- 3. ระบบคลิกแล้ว "บัค + เสียงคอมโบ"
tool.Activated:Connect(function()
    local target = mouse.Target 
    
    if target and not target:IsA("Terrain") and target.Name ~= "Baseplate" then
        target.Anchored = false 
        
        -- --- [ ส่วนของเสียงคอมโบ ] ---
        -- เสียงช็อต
        local sfxShock = Instance.new("Sound")
        sfxShock.SoundId = "rbxassetid://1191305459"
        sfxShock.Volume = 1.5
        sfxShock.Parent = target
        sfxShock:Play()
        
        -- เสียง Error
        local sfxError = Instance.new("Sound")
        sfxError.SoundId = "rbxassetid://21433711"
        sfxError.Volume = 1.2
        sfxError.Parent = target
        sfxError:Play()
        
        -- ลบเสียงทิ้งเมื่อเล่นจบ
        game:GetService("Debris"):AddItem(sfxShock, 2)
        game:GetService("Debris"):AddItem(sfxError, 2)
        -- -------------------------

        task.spawn(function()
            for i = 1, 100 do
                task.wait(0.03)
                target.Color = Color3.new(math.random(), math.random(), math.random())
                target.Material = Enum.Material.Neon
                target.CFrame = target.CFrame * CFrame.Angles(
                    math.rad(math.random(-180, 180)),
                    math.rad(math.random(-180, 180)),
                    math.rad(math.random(-180, 180))
                )
                target.Velocity = Vector3.new(math.random(-60, 60), 70, math.random(-60, 60))
            end
        end)
    end
end)

print("🪄 ไม้บัคอัปเกรดเสียง: จิ้มทีเดียวหูแตก!")

 -- ไม้บัคสีแดง -- 
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local backpack = player:WaitForChild("Backpack")

-- 1. สร้าง Tool 🪄
local tool = Instance.new("Tool")
tool.Name = "ไม้บัคสีแดง"
tool.RequiresHandle = true
tool.Parent = backpack

-- 2. สร้างด้ามไม้ (Black & Red)
local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(15, 15, 15) -- ดำสนิทขรึมๆ
handle.Material = Enum.Material.Wood
handle.Parent = tool

-- ฟังก์ชันสร้างวงแหวนสีแดง (ตามที่ขอ)
local function createRedRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.35, 0.1, 0.35)
    ring.Color = Color3.fromRGB(255, 0, 0) -- สีแดงสด
    ring.Material = Enum.Material.Neon -- ให้เรืองแสงนิดๆ ดูขลัง
    ring.CanCollide = false
    ring.Parent = tool
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = handle
    weld.Part1 = ring
    weld.Parent = ring
    ring.CFrame = handle.CFrame * CFrame.new(0, offset, 0)
end

createRedRing(-1.2)
createRedRing(-0.8)

-- 3. ระบบ "จิ้มแล้วหดจนหาย" (The Eraser Logic)
tool.Activated:Connect(function()
    local target = mouse.Target 
    
    -- ไม่ลบพื้นแมพ (Baseplate) และไม่ลบตัวเอง
    if target and not target:IsA("Terrain") and target.Name ~= "Baseplate" and not target:IsDescendantOf(player.Character) then
        
        -- ใส่เสียงตอนเริ่มลบ (Digital Dissolve)
        local sfx = Instance.new("Sound", target)
        sfx.SoundId = "rbxassetid://131237241" -- เสียงเหมือนของหาย
        sfx.Volume = 1
        sfx:Play()

        task.spawn(function()
            -- ลูปทำให้หดตัว
            for i = 1, 20 do
                task.wait(0.05)
                if target then
                    target.Size = target.Size * 0.7 -- หดลงทีละ 30%
                    target.Transparency = target.Transparency + 0.05 -- ค่อยๆ จางลง
                    
                    -- เพิ่มความบัค: สั่นนิดๆ ก่อนหาย
                    target.CFrame = target.CFrame * CFrame.new(math.random(-1,1)/10, 0, math.random(-1,1)/10)
                end
            end
            
            -- หายไปจริงๆ (ในหน้าจอเรา)
            if target then
                target:Destroy()
            end
        end)
    end
end)

print("🔴 Eraser Wand: จิ้มเพื่อลบทุกอย่าง!")

 -- ไม้บัคสีขาว -- 
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local backpack = player:WaitForChild("Backpack")

-- 1. สร้าง Tool 🪄 (ไม้ดำวงแหวนขาวด้าน)
local tool = Instance.new("Tool")
tool.Name = "ไม้บัคสีขาว"
tool.RequiresHandle = true
tool.Parent = backpack

local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(20, 20, 20)
handle.Material = Enum.Material.Wood
handle.Parent = tool

local function createWhiteRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.36, 0.15, 0.36)
    ring.Color = Color3.fromRGB(240, 240, 240)
    ring.Material = Enum.Material.SmoothPlastic
    ring.CanCollide = false
    ring.Parent = tool
    local weld = Instance.new("WeldConstraint", ring)
    weld.Part0 = handle; weld.Part1 = ring
    weld.Parent = ring
    ring.CFrame = handle.CFrame * CFrame.new(0, offset, 0)
end
createWhiteRing(-1.2)
createWhiteRing(-0.8)

-- 2. คลังแสงไอเทมสุ่ม (ปรับขนาดให้ใหญ่ขึ้นเพื่อให้เห็นชัดๆ)
local morphItems = {
    {Name = "🥤 Coke", Color = Color3.new(0.5, 0, 0), Mat = Enum.Material.Glass, Size = Vector3.new(2, 4, 2)},
    {Name = "🪵 Log", Color = Color3.new(0.3, 0.2, 0.1), Mat = Enum.Material.Wood, Size = Vector3.new(3, 6, 3)},
    {Name = "☁️ Cloud", Color = Color3.new(1, 1, 1), Mat = Enum.Material.Fabric, Size = Vector3.new(6, 3, 6)},
    {Name = "🔫 Gun", Color = Color3.new(0.1, 0.1, 0.1), Mat = Enum.Material.Metal, Size = Vector3.new(2, 2, 4)},
    {Name = "🍎 Apple", Color = Color3.new(1, 0, 0), Mat = Enum.Material.Plastic, Size = Vector3.new(2, 2, 2)},
    {Name = "🚽 Toilet", Color = Color3.new(1, 1, 1), Mat = Enum.Material.Marble, Size = Vector3.new(4, 4, 4)},
    {Name = "🍔 Burger", Color = Color3.fromRGB(150, 100, 50), Mat = Enum.Material.Plastic, Size = Vector3.new(3, 2, 3)}
}

-- 3. ระบบจิ้มแล้วเสก (เน้นเสกทับที่เดิม)
tool.Activated:Connect(function()
    local target = mouse.Target
    if not target or target.Name == "Baseplate" or target:IsA("Terrain") then return end
    
    local oldPos = target.Position
    
    -- แทนที่จะลบ (ซึ่งบางทีลบไม่ได้) ให้ทำให้มันมองไม่เห็นแทน
    if target.Parent:FindFirstChild("Humanoid") then
        target.Parent:MoveTo(Vector3.new(0, -500, 0)) -- ส่งคนลงนรก (ใต้แมพ)
    else
        target.Transparency = 1
        target.CanCollide = false
        target.Position = target.Position + Vector3.new(0, -500, 0) -- ย้ายของหนีไปไกลๆ
    end

    -- สุ่มของใหม่มาวางที่เดิม
    local data = morphItems[math.random(1, #morphItems)]
    local p = Instance.new("Part")
    p.Name = "MorphedItem"
    p.Position = oldPos + Vector3.new(0, 3, 0) -- เสกลอยขึ้นมานิดนึงให้เห็นชัดๆ
    p.Size = data.Size
    p.Color = data.Color
    p.Material = data.Mat
    p.Anchored = true
    p.CanCollide = true
    p.Parent = game.Workspace
    
    -- เสียง Pop!
    local s = Instance.new("Sound", p)
    s.SoundId = "rbxassetid://131237241"
    s.Volume = 2
    s:Play()

    print("🪄 เสกเป็น: " .. data.Name)
    game:GetService("Debris"):AddItem(p, 10)
end)

 -- ไม้บัคสีนํ้าเงิน --
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local backpack = player:WaitForChild("Backpack")

-- 1. สร้าง Tool 🪄 (ไม้ดำวงแหวนน้ำเงิน)
local tool = Instance.new("Tool")
tool.Name = "ไม้บัคสีนํ้าเงิน"
tool.RequiresHandle = true
tool.Parent = backpack

-- 2. สร้างด้ามไม้ (Black Model)
local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(15, 15, 15)
handle.Material = Enum.Material.Wood
handle.Parent = tool

-- วงแหวนประดับ 2 จุด (สีน้ำเงิน Smooth Plastic)
local function createBlueRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.36, 0.15, 0.36)
    ring.Color = Color3.fromRGB(0, 85, 255) -- สีน้ำเงินเข้มสวยๆ
    ring.Material = Enum.Material.SmoothPlastic
    ring.CanCollide = false
    ring.Parent = tool
    local weld = Instance.new("WeldConstraint", ring)
    weld.Part0 = handle; weld.Part1 = ring
    weld.Parent = ring
    ring.CFrame = handle.CFrame * CFrame.new(0, offset, 0)
end

createBlueRing(-1.2)
createBlueRing(-0.8)

-- 3. ระบบจิ้มแล้ว "สลับขั้ว" (Flip Logic)
tool.Activated:Connect(function()
    local target = mouse.Target
    if not target or target.Name == "Baseplate" or target:IsA("Terrain") then return end
    
    -- หาโมเดลหลัก (ถ้าเป็นคนให้เลือกทั้งตัว)
    local model = target.Parent:FindFirstChild("Humanoid") and target.Parent or target
    
    -- เสียง Warp แบบมึนๆ
    local s = Instance.new("Sound", target)
    s.SoundId = "rbxassetid://21433711"
    s.Pitch = 0.5 -- ปรับเสียงให้ต่ำลงดูหลอนๆ
    s:Play()

    -- ระบบสลับขั้ว (หมุน 180 องศา)
    if model:IsA("Model") then
        local primary = model.PrimaryPart or target
        model:SetPrimaryPartCFrame(primary.CFrame * CFrame.Angles(math.rad(180), 0, 0))
    else
        model.CFrame = model.CFrame * CFrame.Angles(math.rad(180), 0, 0)
    end
    
    -- ทำให้ขยับได้แต่หัวทิ่ม (ถ้าไม่ Anchored)
    if target:IsA("BasePart") then
        target.Anchored = false
    end

    print("🔵 Flipped: " .. target.Name)
end)

print("🔵 Dimension Flipper Wand Ready!")

 -- ไม้บัคสีม่วง -- 
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local backpack = player:WaitForChild("Backpack")

-- 1. สร้าง Tool 🪄 (ไม้ดำวงแหวนม่วง)
local tool = Instance.new("Tool")
tool.Name = "ไม้บัคสีม่วง"
tool.RequiresHandle = true
tool.Parent = backpack

local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(15, 15, 15)
handle.Material = Enum.Material.Wood
handle.Parent = tool

-- วงแหวนประดับ 2 จุด (สีม่วง Smooth Plastic)
local function createPurpleRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.36, 0.15, 0.36)
    ring.Color = Color3.fromRGB(170, 0, 255) -- สีม่วงเข้ม
    ring.Material = Enum.Material.SmoothPlastic
    ring.CanCollide = false
    ring.Parent = tool
    local weld = Instance.new("WeldConstraint", ring)
    weld.Part0 = handle; weld.Part1 = ring
    weld.Parent = ring
    ring.CFrame = handle.CFrame * CFrame.new(0, offset, 0)
end

createPurpleRing(-1.2)
createPurpleRing(-0.8)

-- 2. ฟังก์ชันเรียกอุกกาบาต (Meteor Logic)
local function spawnMeteor(targetPos)
    -- สร้างลูกอุกกาบาต
    local meteor = Instance.new("Part")
    meteor.Shape = Enum.PartType.Ball
    meteor.Size = Vector3.new(10, 10, 10)
    meteor.Color = Color3.fromRGB(50, 50, 50)
    meteor.Material = Enum.Material.Slate
    meteor.CanCollide = false
    meteor.Position = targetPos + Vector3.new(math.random(-10,10), 100, math.random(-10,10)) -- เสกบนฟ้า
    meteor.Parent = game.Workspace

    -- เอฟเฟกต์ไฟลุก
    local fire = Instance.new("Fire", meteor)
    fire.Size = 20
    fire.Heat = 25

    -- เสียงหวีดตอนตก
    local sfxWhistle = Instance.new("Sound", meteor)
    sfxWhistle.SoundId = "rbxassetid://134333113"
    sfxWhistle.Volume = 2
    sfxWhistle:Play()

    -- ทำให้มันพุ่งลงมา
    local bodyVelocity = Instance.new("BodyVelocity", meteor)
    bodyVelocity.Velocity = Vector3.new(0, -150, 0)
    bodyVelocity.MaxForce = Vector3.new(4e5, 4e5, 4e5)

    -- เมื่อถึงพื้น (หรือไกล้จุดจิ้ม)
    task.spawn(function()
        while meteor.Position.Y > targetPos.Y + 5 do
            task.wait(0.1)
        end
        
        -- ระเบิด!
        local explosion = Instance.new("Explosion")
        explosion.Position = meteor.Position
        explosion.BlastRadius = 20
        explosion.Parent = game.Workspace
        
        -- เสียงระเบิด
        local sfxBoom = Instance.new("Sound", game.Workspace)
        sfxBoom.SoundId = "rbxassetid://12222030"
        sfxBoom.Volume = 3
        sfxBoom:Play()
        
        meteor:Destroy()
        game:GetService("Debris"):AddItem(sfxBoom, 3)
    end)
end

-- 3. ระบบจิ้มแล้วเรียก
tool.Activated:Connect(function()
    local targetPos = mouse.Hit.p -- เอาตำแหน่งที่จิ้ม (ไม่ว่าจะโดนอะไร)
    
    -- เสียงร่ายเวท
    local sfxMagic = Instance.new("Sound", handle)
    sfxMagic.SoundId = "rbxassetid://21433711"
    sfxMagic.Pitch = 0.7
    sfxMagic:Play()

    spawnMeteor(targetPos)
    print("🟣 Meteor Summoned at: " .. tostring(targetPos))
end)

print("🟣 Meteor Wand Ready! ระวังหัวแบะ!")

-- ไม้บัคสีชมพู --
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

-- สร้าง Tool (ไม้อันที่ 6)
local pinkWand = Instance.new("Tool")
pinkWand.Name = "ไม้บัคสีชมพู"
pinkWand.RequiresHandle = true
pinkWand.Parent = player.Backpack

-- 1. Handle ตามมาตรฐาน (Black Wood, Size 0.3, 3.8, 0.3)
local handle = Instance.new("Part")
handle.Name = "Handle"
handle.Size = Vector3.new(0.3, 3.8, 0.3)
handle.Color = Color3.fromRGB(15, 15, 15) -- สีดำตามสั่ง
handle.Material = Enum.Material.Wood
handle.Parent = pinkWand

-- 2. Ring 2 จุดตามมาตรฐาน (Offset -1.2 และ -0.8, Neon Pink)
local function createPinkRing(offset)
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(0.35, 0.1, 0.35)
    ring.Material = Enum.Material.Neon
    ring.Color = Color3.fromRGB(255, 105, 180) -- Hot Pink!
    ring.CanCollide = false
    ring.Parent = handle
    
    local weld = Instance.new("Weld")
    weld.Part0 = handle
    weld.Part1 = ring
    weld.C0 = CFrame.new(0, offset, 0)
    weld.Parent = ring
end

createPinkRing(-1.2)
createPinkRing(-0.8)

-- [ พลังของไม้อันที่ 6: Pink Blink & Boom ] --
pinkWand.Activated:Connect(function()
    local targetPos = mouse.Hit.p
    local char = player.Character
    
    if char and char:FindFirstChild("HumanoidRootPart") then
        -- ระเบิดสีชมพูตรงจุดที่คลิก (BlastPressure 0 = ไม่ตาย)
        local ex = Instance.new("Explosion")
        ex.Position = targetPos
        ex.BlastRadius = 15
        ex.BlastPressure = 0 
        ex.Parent = workspace
        
        -- เอฟเฟกต์แสงสีชมพูวาบขึ้นมา (Visual Item)
        local flash = Instance.new("Part")
        flash.Shape = Enum.PartType.Ball
        flash.Size = Vector3.new(1, 1, 1)
        flash.Position = targetPos
        flash.Color = Color3.fromRGB(255, 20, 147)
        flash.Material = Enum.Material.Neon
        flash.Anchored = true
        flash.CanCollide = false
        flash.Parent = workspace
        
        -- วาร์ปตัวเราไปทันที!
        char.HumanoidRootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
        
        -- ลบเอฟเฟกต์ทิ้ง
        spawn(function()
            for i = 1, 10 do
                flash.Size = flash.Size + Vector3.new(2, 2, 2)
                flash.Transparency = flash.Transparency + 0.1
                task.wait(0.02)
            end
            flash:Destroy()
        end)
    end
end)
