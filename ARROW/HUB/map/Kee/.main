-- สคริปแมพขี้ --
local lp = game:GetService("Players").LocalPlayer
local pgui = lp:WaitForChild("PlayerGui")
local UserInputService = game:GetService("UserInputService")

-- [ ล้าง UI เก่า ]
if pgui:FindFirstChild("ArrowHubPoop") then pgui.ArrowHubPoop:Destroy() end

local ScreenGui = Instance.new("ScreenGui", pgui)
ScreenGui.Name = "ArrowHubPoop"
ScreenGui.ResetOnSpawn = false

-- ฟังก์ชั่นทำให้ UI ลากได้ (รองรับมือถือ)
local function makeDraggable(gui)
    local dragging, dragInput, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = gui.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- 1. [ปุ่มเปิด-ปิด รูปนกอินทรี ลากได้]
local ToggleBtn = Instance.new("ImageButton", ScreenGui)
ToggleBtn.Size = UDim2.new(0, 60, 0, 60)
ToggleBtn.Position = UDim2.new(0, 20, 0.5, -30)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
ToggleBtn.Image = "rbxassetid://96992259840286"
Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1, 0)
local Stroke = Instance.new("UIStroke", ToggleBtn)
Stroke.Color = Color3.fromRGB(255, 0, 0)
Stroke.Thickness = 2
makeDraggable(ToggleBtn)

-- 2. [เมนูหลัก]
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 220, 0, 200)
MainFrame.Position = UDim2.new(0.5, -110, 0.5, -100)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.Visible = false
MainFrame.Active = true
Instance.new("UICorner", MainFrame)
makeDraggable(MainFrame)

-- หัวข้อเมนู
local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Text = "ARROW HUB POOP"
Title.TextColor3 = Color3.fromRGB(255, 0, 0)
Title.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 16

-- ฟังก์ชั่นยิง Remote
local function firePoop()
    local args = { buffer.fromstring("\000\000\000\000") }
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Packets"):WaitForChild("Packet"):WaitForChild("RemoteEvent")
    remote:FireServer(unpack(args))
end

-- 3. [ปุ่มที่ 1: เสกขี้]
local PoopOnceBtn = Instance.new("TextButton", MainFrame)
PoopOnceBtn.Size = UDim2.new(0.85, 0, 0, 40)
PoopOnceBtn.Position = UDim2.new(0.075, 0, 0.3, 0)
PoopOnceBtn.BackgroundColor3 = Color3.fromRGB(100, 50, 0) -- สีน้ำตาลขี้
PoopOnceBtn.Text = "เสกขี้"
PoopOnceBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
PoopOnceBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", PoopOnceBtn)

PoopOnceBtn.MouseButton1Click:Connect(function()
    firePoop()
end)

-- 4. [ปุ่มที่ 2: สวิตช์เสกขี้รัวๆ]
local AutoPoopBtn = Instance.new("TextButton", MainFrame)
AutoPoopBtn.Size = UDim2.new(0.85, 0, 0, 40)
AutoPoopBtn.Position = UDim2.new(0.075, 0, 0.6, 0)
AutoPoopBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
AutoPoopBtn.Text = "เสกขี้รัวๆ: ปิด"
AutoPoopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
AutoPoopBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", AutoPoopBtn)

local autoEnabled = false
AutoPoopBtn.MouseButton1Click:Connect(function()
    autoEnabled = not autoEnabled
    if autoEnabled then
        AutoPoopBtn.Text = "เสกขี้รัวๆ: เปิดอยู่"
        AutoPoopBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    else
        AutoPoopBtn.Text = "เสกขี้รัวๆ: ปิด"
        AutoPoopBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

-- ระบบ Loop เสกขี้รัวๆ
task.spawn(function()
    while true do
        if autoEnabled then
            firePoop()
        end
        task.wait(0.75)
    end
end)

-- ระบบเปิด/ปิดเมนู
ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)
