local function GetClosest()
    local target, shortestDist = nil, Settings.FovRadius
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild(_0x1("\72\101\97\100")) then
            if Settings.TeamCheck and v.Team == lp.Team then continue end
            if Settings.KillCheck and v.Character:FindFirstChild(_0x1("\72\117\109\97\110\111\105\100")) and v.Character.Humanoid.Health <= 0 then continue end
            
            local pos, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < shortestDist then
                    target = v
                    shortestDist = mag
                end
            end
        end
    end
    return target
end

